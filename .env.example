# apiforge example configuration. Copy to .env and adjust; every value is an
# environment variable (the gateway reads env, not this file directly — load it
# with your process manager, e.g. `set -a; . ./.env; set +a; ./apiforge`).

# ── Core ────────────────────────────────────────────────────────────────────
API_KEYS=sk-change-me                 # client access keys (comma-separated)
HOST=127.0.0.1                        # bind loopback; use 0.0.0.0 only in a container
PORT=8899
LOG_LEVEL=info                        # debug|info|warn|error
ADMIN_TOKEN=                          # set to enable /admin/* (account control)

# ── Pool / concurrency ───────────────────────────────────────────────────────
MAX_ACCOUNT_CONCURRENCY=3             # per-account cap (0 = unlimited)
QUEUE_WAIT_MS=60000                   # queue time when all accounts are at cap
STICKY_TTL_SECONDS=0                  # session→account affinity (x-apiforge-session)
RATE_LIMIT_RPM=0                      # per-key requests/min (0 = off)
MAX_BODY_BYTES=10485760               # request body cap (0 = unlimited)

# ── Subscription / CLI login reuse (auto-detected if you're logged in) ───────
# CODEX_AUTHS=/home/you/.codex/auth.json           # multiple = comma-separated
# CLAUDE_AUTHS=/home/you/.claude/.credentials.json
# QWEN_AUTHS=/home/you/.qwen/oauth_creds.json
# COPILOT_GITHUB_TOKENS=gho_xxx                     # or auto from github-copilot config
# GEMINI_OAUTH_ENABLED=true                         # experimental
# GEMINI_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com   # public gemini-cli client (not vendored here)
# GEMINI_OAUTH_CLIENT_SECRET=xxx
# CURSOR_ACCESS_TOKEN=eyJ...                        # experimental (from state.vscdb)
# GROK_COOKIES=sso=xxxx                             # experimental; or "sso=xxx; cf_clearance=yyy"
# Disable a source explicitly:
# CURSOR_ENABLED=false

# ── Official / API-key upstreams (mixed into the same pools) ─────────────────
# OPENAI_API_KEYS=sk-...
# ANTHROPIC_API_KEYS=sk-ant-...
# DEEPSEEK_API_KEYS=sk-...
# MOONSHOT_API_KEYS=sk-...
# ZHIPU_API_KEYS=...
# XAI_API_KEYS=xai-...                              # official Grok API key
# OPENROUTER_API_KEYS=sk-or-...
# ...see internal/provider/vendors.go for the full list of *_API_KEYS

# ── Custom relay(s) ──────────────────────────────────────────────────────────
# CUSTOM_PROVIDERS=[{"id":"myrelay","baseUrl":"https://api.example.com","models":["x"],"apiKeys":["k"]}]
# CUSTOM_PROVIDERS_FILE=/path/to/providers.json
