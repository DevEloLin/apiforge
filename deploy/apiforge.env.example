# apiforge configuration file (KEY=VALUE).
#
# Standard config directory (nginx/haproxy/wireguard style), auto-discovered:
#   /etc/apiforge/apiforge.env   this file (main config; 0600 — it holds secrets)
#   /etc/apiforge/conf.d/*.env   drop-in overrides (loaded after, later wins)
#   /etc/apiforge/creds/         copy your CLI login / authorization files here
# The binary finds it automatically (also ~/.config/apiforge, ~/.apiforge, ./).
# Force one: `apiforge -config-dir /etc/apiforge` or `apiforge -env-file <file>`.
# A real environment variable overrides a value here. Full reference: docs/OPERATIONS.md.

# ── Core ────────────────────────────────────────────────────────────────────
API_KEYS=sk-change-me            # client access keys (comma-separated)
HOST=127.0.0.1                   # bind loopback; front with new-api/Cloudflare for public access
PORT=8899
LOG_LEVEL=info                   # debug|info|warn|error
# ADMIN_TOKEN=change-me-admin    # enables /admin/* account control

# ── Pool / concurrency ──────────────────────────────────────────────────────
MAX_ACCOUNT_CONCURRENCY=3        # per-account cap (0 = unlimited)
QUEUE_WAIT_MS=60000              # how long a request queues for a free slot
STICKY_TTL_SECONDS=0             # session→account affinity (0 = off)
GOMEMLIMIT=64MiB                 # Go heap soft cap (good on a 1 GB Pi)

# ── Subscription / CLI credentials (ABSOLUTE paths) ──────────────────────────
# Recommended: copy login files into /etc/apiforge/creds/ (token write-back then
# works with the default systemd unit). Use absolute paths (independent of $HOME).
#
# Multi-account, either style:
#   • comma-separated files:  CODEX_AUTHS=/etc/apiforge/creds/codex/a.json,/etc/apiforge/creds/codex/b.json
#   • a DIRECTORY of *.json (one file per account, cleaner):
#       CODEX_AUTHS=/etc/apiforge/creds/codex        # → each *.json = one account
# (creds/<provider>/ is also auto-discovered even without *_AUTHS)
# CODEX_AUTHS=/etc/apiforge/creds/codex
# CLAUDE_AUTHS=/etc/apiforge/creds/claude
# QWEN_AUTHS=/etc/apiforge/creds/qwen
# For grok/cursor/vendors, multi-account = comma-separated tokens/keys (below)
# COPILOT_GITHUB_TOKENS=gho_xxx
# GROK_COOKIES=sso=xxxx                         # experimental
# CURSOR_ACCESS_TOKEN=eyJ...                    # experimental
# GEMINI_OAUTH_ENABLED=true                     # experimental (+ GEMINI_OAUTH_CLIENT_ID/_SECRET)

# ── Official / vendor API keys (optional; mixed into the pools) ──────────────
# OPENAI_API_KEYS=sk-...
# ANTHROPIC_API_KEYS=sk-ant-...
# DEEPSEEK_API_KEYS=sk-...
# XAI_API_KEYS=xai-...
